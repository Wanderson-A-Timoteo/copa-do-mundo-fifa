generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  TORCEDOR
  ADMIN
}

enum FasePartida {
  GRUPOS
  SEGUNDAS
  OITAVAS
  QUARTAS
  SEMI
  TERCEIRO
  FINAL
}

enum StatusTroca {
  pendente
  aceita
  recusada
}

enum TipoFigurinha {
  jogador
}

enum RaridadeFigurinha {
  comum
  rara
}

enum PosicaoJogador {
  Goleiro
  Defensor
  Meia
  Atacante
}

model User {
  id        Int      @id @default(autoincrement())
  nome      String
  slug      String   @unique
  email     String   @unique
  senha     String?
  role      UserRole @default(TORCEDOR)
  createdAt DateTime @default(now())  @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  ultimoDiaAbertura   DateTime?  @map("ultimo_dia_abertura")
  pacotesAbertosHoje  Int        @default(0) @map("pacotes_abertos_hoje")

  albumFigurinhas AlbumFigurinha[]
  trocasEnviadas  Troca[]         @relation("troca_remetente")
  trocasRecebidas Troca[]         @relation("troca_destinatario")
  palpites            Palpite[]
  palpitesMataMata    PalpiteMataMata[]
  simulacoes          Simulacao[]
  simulacoesMataMata  SimulacaoMataMata[]

  @@index([role])
  @@map("users")
}

model Grupo {
  id        String    @id
  nome      String    @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  selecoes  Selecao[]
  partidas  Partida[]

  @@map("grupos")
}

model Selecao {
  id            Int       @id @default(autoincrement())
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")
  nome          String
  slug          String?   @unique
  codigoPais    String?
  bandeiraUrl   String?
  grupoId       String
  grupo         Grupo     @relation(fields: [grupoId], references: [id])
  tecnico       String?
  continente    String
  rankingFifa   Int?
  corPrimaria   String?
  corSecundaria String?
  titulos       Int       @default(0)

  jogadores    Jogador[]
  figurinhas   Figurinha[]
  partidasCasa   Partida[] @relation("mandante")
  partidasFora   Partida[] @relation("visitante")
  partidasVencidas Partida[] @relation("vencedor")

  @@index([grupoId])
  @@map("selecoes")
}

model Jogador {
  id            Int       @id @default(autoincrement())
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")
  selecaoId     Int
  selecao       Selecao   @relation(fields: [selecaoId], references: [id])
  nome          String
  numeroCamisa  Int?
  posicao       PosicaoJogador
  dataNascimento DateTime?
  fotoUrl       String?
  altura        Int?
  peso          Int?

  figurinha Figurinha?

  @@index([selecaoId])
  @@map("jogadores")
}

model Estadio {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  slug        String   @unique
  nome        String
  cidade      String
  pais        String
  capacidade  Int
  fotoUrl     String?
  galeria     String[] @default([])
  descricao   String?
  historia    String?
  curiosidades String[] @default([])
  latitude    Float?
  longitude   Float?
  partidas    Partida[]

  @@map("estadios")
}

model Partida {
  id                  Int      @id @default(autoincrement())
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at")
  fase                FasePartida
  grupoId             String?
  grupo               Grupo?   @relation(fields: [grupoId], references: [id])
  selecaoMandanteId   Int?
  selecaoVisitanteId  Int?
  mandante            Selecao?  @relation("mandante", fields: [selecaoMandanteId], references: [id])
  visitante           Selecao?  @relation("visitante", fields: [selecaoVisitanteId], references: [id])
  dataHora            DateTime
  estadioId           Int
  estadio             Estadio  @relation(fields: [estadioId], references: [id])
  golsMandante        Int?
  golsVisitante       Int?
  encerrada           Boolean  @default(false)
  vencedorId          Int?
  vencedor            Selecao? @relation("vencedor", fields: [vencedorId], references: [id])

  palpites            Palpite[]
  palpitesMataMata    PalpiteMataMata[]
  simulacoes          Simulacao[]
  simulacoesMataMata  SimulacaoMataMata[]
  resultadoOficial    ResultadoOficial?

  @@index([selecaoMandanteId])
  @@index([selecaoVisitanteId])
  @@index([estadioId])
  @@index([grupoId])
  @@index([fase])
  @@index([encerrada])
  @@map("partidas")
}

model Figurinha {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  numero    Int
  selecaoId Int
  selecao   Selecao  @relation(fields: [selecaoId], references: [id])
  jogadorId Int?     @unique
  jogador   Jogador? @relation(fields: [jogadorId], references: [id])
  tipo      TipoFigurinha   @default(jogador)
  raridade  RaridadeFigurinha   @default(comum)
  imagemUrl String?
  slug      String   @unique

  albumUsuarios          AlbumFigurinha[]
  trocasDesejadas        Troca[]                     @relation("desejada")
  oferecidaEmTrocas      TrocaFigurinhaOferecida[]

  @@index([selecaoId])
  @@unique([selecaoId, numero])
  @@map("figurinhas")
}

model AlbumFigurinha {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  usuarioId   Int
  usuario     User     @relation(fields: [usuarioId], references: [id])
  figurinhaId Int
  figurinha   Figurinha @relation(fields: [figurinhaId], references: [id])
  quantidade  Int      @default(1)

  @@unique([usuarioId, figurinhaId])
  @@index([quantidade])
  @@map("album_figurinhas")
}

model Troca {
  id                  Int      @id @default(autoincrement())
  remetenteId         Int
  remetente           User     @relation("troca_remetente", fields: [remetenteId], references: [id])
  destinatarioId      Int
  destinatario        User     @relation("troca_destinatario", fields: [destinatarioId], references: [id])
  figurinhaDesejadaId Int
  figurinhaDesejada   Figurinha @relation("desejada", fields: [figurinhaDesejadaId], references: [id])
  status              StatusTroca   @default(pendente)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at")

  figurinhasOferecidas TrocaFigurinhaOferecida[]

  @@index([remetenteId])
  @@index([destinatarioId])
  @@index([status])
  @@map("trocas")
}

model TrocaFigurinhaOferecida {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  trocaId     Int
  troca       Troca    @relation(fields: [trocaId], references: [id], onDelete: Cascade)
  figurinhaId Int
  figurinha   Figurinha @relation(fields: [figurinhaId], references: [id])

  @@unique([trocaId, figurinhaId])
  @@index([figurinhaId])
  @@map("troca_figurinhas_oferecidas")
}

model Palpite {
  id            Int      @id @default(autoincrement())
  usuarioId     Int
  usuario       User     @relation(fields: [usuarioId], references: [id])
  partidaId     Int
  partida       Partida  @relation(fields: [partidaId], references: [id])
  golsMandante  Int
  golsVisitante Int
  pontos        Int?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([usuarioId, partidaId])
  @@index([partidaId])
  @@map("palpites")
}

model ResultadoOficial {
  id                Int      @id @default(autoincrement())
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")
  partidaId         Int      @unique @map("partida_id")
  partida           Partida  @relation(fields: [partidaId], references: [id])
  golsMandante      Int?     @map("gols_mandante")
  golsVisitante     Int?     @map("gols_visitante")
  penaltisMandante  Int?     @map("penaltis_mandante")
  penaltisVisitante Int?     @map("penaltis_visitante")

  @@map("resultados_oficiais")
}

model PalpiteMataMata {
  id            Int      @id @default(autoincrement())
  usuarioId     Int
  usuario       User     @relation(fields: [usuarioId], references: [id])
  partidaId     Int
  partida       Partida  @relation(fields: [partidaId], references: [id])
  golsMandante      Int?
  golsVisitante     Int?
  penaltisMandante  Int?
  penaltisVisitante Int?
  pontos        Int?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([usuarioId, partidaId])
  @@index([partidaId])
  @@map("palpites_mata_mata")
}

model Simulacao {
  id            Int      @id @default(autoincrement())
  usuarioId     Int
  usuario       User     @relation(fields: [usuarioId], references: [id])
  partidaId     Int
  partida       Partida  @relation(fields: [partidaId], references: [id])
  golsMandante  Int
  golsVisitante Int
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([usuarioId, partidaId])
  @@index([partidaId])
  @@map("simulacoes")
}

model SimulacaoMataMata {
  id                Int      @id @default(autoincrement())
  usuarioId         Int
  usuario           User     @relation(fields: [usuarioId], references: [id])
  partidaId         Int
  partida           Partida  @relation(fields: [partidaId], references: [id])
  golsMandante      Int?
  golsVisitante     Int?
  penaltisMandante  Int?
  penaltisVisitante Int?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([usuarioId, partidaId])
  @@index([partidaId])
  @@map("simulacoes_mata_mata")
}
