generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  albumFigurinhas AlbumFigurinha[]
  trocasEnviadas  Troca[]         @relation("troca_remetente")
  trocasRecebidas Troca[]         @relation("troca_destinatario")
  palpites        Palpite[]

  @@map("users")
}

model Grupo {
  id        String    @id
  nome      String    @unique
  selecoes  Selecao[]
  partidas  Partida[]

  @@map("grupos")
}

model Selecao {
  id            Int       @id @default(autoincrement())
  nome          String
  bandeiraUrl   String?
  grupoId       String
  grupo         Grupo     @relation(fields: [grupoId], references: [id])
  tecnico       String?
  continente    String
  rankingFifa   Int?
  corPrimaria   String?
  corSecundaria String?
  titulos       Int       @default(0)

  jogadores    Jogador[]
  figurinhas   Figurinha[]
  partidasCasa Partida[] @relation("mandante")
  partidasFora Partida[] @relation("visitante")

  @@map("selecoes")
}

model Jogador {
  id            Int       @id @default(autoincrement())
  selecaoId     Int
  selecao       Selecao   @relation(fields: [selecaoId], references: [id])
  nome          String
  numeroCamisa  Int?
  posicao       String
  dataNascimento DateTime?
  fotoUrl       String?

  figurinha Figurinha?

  @@map("jogadores")
}

model Estadio {
  id          Int      @id @default(autoincrement())
  nome        String
  cidade      String
  pais        String
  capacidade  Int
  fotoUrl     String?
  latitude    Float?
  longitude   Float?
  partidas    Partida[]

  @@map("estadios")
}

model Partida {
  id                  Int      @id @default(autoincrement())
  fase                String
  grupoId             String?
  grupo               Grupo?   @relation(fields: [grupoId], references: [id])
  selecaoMandanteId   Int
  selecaoVisitanteId  Int
  mandante            Selecao  @relation("mandante", fields: [selecaoMandanteId], references: [id])
  visitante           Selecao  @relation("visitante", fields: [selecaoVisitanteId], references: [id])
  dataHora            DateTime
  estadioId           Int
  estadio             Estadio  @relation(fields: [estadioId], references: [id])
  golsMandante        Int?
  golsVisitante       Int?
  encerrada           Boolean  @default(false)
  vencedorId          Int?

  palpites Palpite[]

  @@map("partidas")
}

model Figurinha {
  id        Int      @id @default(autoincrement())
  numero    Int
  selecaoId Int
  selecao   Selecao  @relation(fields: [selecaoId], references: [id])
  jogadorId Int?     @unique
  jogador   Jogador? @relation(fields: [jogadorId], references: [id])
  tipo      String   @default("jogador")
  raridade  String   @default("comum")
  imagemUrl String?

  albumUsuarios    AlbumFigurinha[]
  trocasOferecidas Troca[] @relation("oferecida")
  trocasDesejadas  Troca[] @relation("desejada")

  @@map("figurinhas")
}

model AlbumFigurinha {
  id          Int      @id @default(autoincrement())
  usuarioId   Int
  usuario     User     @relation(fields: [usuarioId], references: [id])
  figurinhaId Int
  figurinha   Figurinha @relation(fields: [figurinhaId], references: [id])
  quantidade  Int      @default(1)

  @@unique([usuarioId, figurinhaId])
  @@map("album_figurinhas")
}

model Troca {
  id                    Int      @id @default(autoincrement())
  remetenteId           Int
  remetente             User     @relation("troca_remetente", fields: [remetenteId], references: [id])
  destinatarioId        Int
  destinatario          User     @relation("troca_destinatario", fields: [destinatarioId], references: [id])
  figurinhaOferecidaId  Int
  figurinhaOferecida    Figurinha @relation("oferecida", fields: [figurinhaOferecidaId], references: [id])
  figurinhaDesejadaId   Int
  figurinhaDesejada     Figurinha @relation("desejada", fields: [figurinhaDesejadaId], references: [id])
  status                String   @default("pendente")
  createdAt             DateTime @default(now()) @map("created_at")

  @@map("trocas")
}

model Palpite {
  id            Int      @id @default(autoincrement())
  usuarioId     Int
  usuario       User     @relation(fields: [usuarioId], references: [id])
  partidaId     Int
  partida       Partida  @relation(fields: [partidaId], references: [id])
  golsMandante  Int
  golsVisitante Int
  pontos        Int?
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([usuarioId, partidaId])
  @@map("palpites")
}
